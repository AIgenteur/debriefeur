# AIgenteur Debrief — Environment Configuration
# This file goes in ~/.debrief/.env (created by `debrief setup`)
# Or set these as regular environment variables.

# ─── Option 1: OpenRouter (recommended) ──────────────────────
# One API key gives you access to 200+ models.
# Get your key: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...
MODEL_TIER_FAST=openrouter/qwen/qwen3.5-397b-a17b
MODEL_TIER_DEEP=openrouter/moonshotai/kimi-k2.5
MODEL_TIER_SYNTHESIS=openrouter/z-ai/glm-5

# ─── Option 2: OpenAI ────────────────────────────────────────
# OPENAI_API_KEY=sk-...
# MODEL_TIER_FAST=openai/gpt-4o-mini
# MODEL_TIER_DEEP=openai/gpt-4o
# MODEL_TIER_SYNTHESIS=openai/gpt-4o

# ─── Option 3: Anthropic ─────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...
# MODEL_TIER_FAST=anthropic/claude-3-haiku-20240307
# MODEL_TIER_DEEP=anthropic/claude-3.5-sonnet
# MODEL_TIER_SYNTHESIS=anthropic/claude-3.5-sonnet

# ─── Option 4: Ollama (fully offline) ────────────────────────
# No API key needed! Just run `ollama serve`
# OLLAMA_API_BASE=http://localhost:11434
# MODEL_TIER_FAST=ollama/qwen3.5:14b
# MODEL_TIER_DEEP=ollama/qwen3.5:14b
# MODEL_TIER_SYNTHESIS=ollama/qwen3.5:14b

# ─── Option 5: Custom endpoint (vLLM, llama.cpp, etc.) ──────
# CUSTOM_API_BASE=http://localhost:8080/v1
# MODEL_TIER_FAST=openai/my-model
# MODEL_TIER_DEEP=openai/my-model
# MODEL_TIER_SYNTHESIS=openai/my-model
